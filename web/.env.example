# LI.FI Composer API Key (get from https://portal.li.fi/)
NEXT_PUBLIC_LIFI_API_KEY=your_api_key_here

# ─── LLM Provider ───────────────────────────────────────────
# Set LLM_PROVIDER to "openai" or "anthropic" (default: openai)
LLM_PROVIDER=openai

# OpenAI-compatible API
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic API
# ANTHROPIC_API_KEY=your_anthropic_key_here
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Shared LLM settings
# LLM_MAX_TOKENS=2048
# LLM_TEMPERATURE=0.3

# WalletConnect Project ID (get from https://cloud.walletconnect.com/)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Local Base fork testing (optional)
# Use a dedicated local chain ID such as 31337 to avoid conflicting with the real Base chain in wallet UIs.
# The deploy helper can sync this block automatically with:
# node scripts/deploy-contract-and-configure-web.mjs --network local_base_fork --sync-local-fork-env
# NEXT_PUBLIC_LOCAL_FORK_ENABLED=true
# NEXT_PUBLIC_LOCAL_FORK_CHAIN_ID=31337
# NEXT_PUBLIC_LOCAL_FORK_SOURCE_CHAIN_ID=8453
# NEXT_PUBLIC_LOCAL_FORK_RPC_URL=http://127.0.0.1:8545
# NEXT_PUBLIC_LOCAL_FORK_NAME=Base Fork Local
# NEXT_PUBLIC_LOCAL_FORK_EXPLORER_URL=

# SafeFlow Contract Address (deployed on Base Sepolia)
NEXT_PUBLIC_SAFEFLOW_CONTRACT=0x0000000000000000000000000000000000000000
